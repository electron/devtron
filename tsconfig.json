{
  "extends": "@tsconfig/node22/tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["DOM"],
    "module": "preserve",
    "moduleResolution": "bundler",
    "types": ["chrome", "node", "webpack-env", "electron", "mocha", "chai"],
    "declaration": false,
    "sourceMap": false,
    "rootDir": "./src",
    "outDir": "./dist",
    "forceConsistentCasingInFileNames": true
  },
  "include": ["./global.d.ts", "./src/**/*"]
}
